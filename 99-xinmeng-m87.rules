# 99-xinmeng-m87.rules
# udev rules for Xinmeng M87 / M87 Pro keyboards
# Copy to /etc/udev/rules.d/ and run:
#   sudo cp 99-xinmeng-m87.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
# Then add yourself to the 'input' group:
#   sudo usermod -aG input $USER
# Log out and back in (or reboot).

# Limit access to hidraw device nodes used by the keyboard software.
# For tighter scoping, replace these vendor-only matches with exact
# supported VID/PID pairs when the product IDs are known.
# Sinowealth VID 0x258A (covers most Xinmeng M87 variants)
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="258a", GROUP="input", MODE="0660"

# Winbond/Generalplus VID 0x0416
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0416", GROUP="input", MODE="0660"

# VID 0x3151
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="3151", GROUP="input", MODE="0660"
